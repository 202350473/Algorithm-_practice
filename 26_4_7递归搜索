//https://www.acwing.com/problem/content/94/  递归实现指数型枚举


#include<bits/stdc++.h>
using namespace std;
const int N=15;
int n;
int st[N];//用来存状态：0初始  1选2不选 

//x表示递归的深度，state存是否已经选了？？？
void dfs(int x){
    //出口
    if(x>n){
        for(int i=1;i<=n;i++){
            if(st[i]==1)cout<<i<<" ";
        }
        cout<<'\n';
        return;
    }
    
    //还未到出口，继续搜索
    //选择1,选：
    st[x]=1; dfs(x+1); st[x]=0;
    
    //选择2，不选：
    st[x]=2; dfs(x+1); st[x]=0;
    
}

int main(){
   cin>>n;
    dfs(1);
    return 0;
    
}